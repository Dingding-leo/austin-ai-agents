{
  "id": "auto-tagger",
  "name": "Auto Tagger",
  "description": "Automatically tag and categorize messages using AI",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "tags": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["important", "todo", "question", "bug", "feature"]
      },
      "autoTag": {
        "type": "boolean",
        "default": true
      }
    }
  }
}
